DATABASE_URL=postgresql://postgres:postgres@localhost:5432/datatest

SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
DEBUG=True

# LLM - Google Gemini (for chatbot agent)
GOOGLE_API_KEY=your-google-api-key

# LangSmith (optional, for tracing/debugging agent)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=movie-chatbot
